[core]
  excludesFile = ~/.config/git/ignore
  attributesFile = ~/.config/git/attributes
  hooksPath = ~/.config/git/hooks
[credential]
  helper = libsecret
[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed-signers
[merge]
  tool = vimdiff
[mergetool]
  keepBackup = false
[user]
  signingKey = ~/.ssh/agent-keys.pub
