      },
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "language_servers": [
        "!eslint",
        "biome",
        "!typescript-language-server",
        "!tsgo",
        "vstls",
        "..."
      ],
      "prettier": {
        "allowed": false
      }
    },
    "XML": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--parser",
            "xml",
            "--plugin={{ .chezmoi.homeDir }}/{{ $cache }}/.bun/install/global/node_modules/@prettier/plugin-xml/src/plugin.js"
          ]
        }
      }
    },
    "YAML": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "yamlfmt",
          "arguments": ["-in"]
        }
      }
