        "source.organizeImports.biome": true
      },
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "language_servers": [
        "biome",
        "!eslint",
        "!stylelint-lsp",
        "!tsgo",
        "vstls",
        "!typescript-language-server",
        "..."
