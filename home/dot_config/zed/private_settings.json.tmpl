          "command": "~/{{ $data }}/gem/bin/erb-formatter",
          "arguments": ["--stdin"]
        }
      },
      "language_servers": [
        "ruby-lsp",
        "!solargraph",
        "rubocop",
        "steep",
        "!sorbet",
        "..."
      ]
