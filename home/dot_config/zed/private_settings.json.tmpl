      "language_servers": [
        "biome",
        "!eslint",
        "!stylelint-lsp",
        "!tsgo",
        "vstls",
        "!typescript-language-server",
        "..."
      ]
    },
    "JS+ERB": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "~/{{ $data }}/gem/bin/erb-formatter",
          "arguments": ["--stdin"]
        }
      },
      "language_servers": [
        "ruby-lsp",
        "!solargraph",
        "rubocop",
        "steep",
        "!sorbet",
        "..."
      ]
    },
    "JSON": {
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
    "JSON5": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "a.jsonc"]
