  // LSP Specific settings.
  "lsp": {
    "django-template-lsp": {
      "binary": {
        "path": "~/{{ $bin }}/djlsp"
      }
    },
    "eslint": {
      "settings": {
        "onIgnoredFiles": "off"
      }
    },
    "gh-actions-language-server": {
      "initialization_options": {
        "sessionToken": "{{ includeTemplate "secret.tmpl" (list "GHA_LANGUAGE_SERVER_TOKEN" "op://Private/bhmimlus3gz3xfqr4xnbobbdje/gh-actions-language-server" $opAccount) }}"
      }
    },
    "gopls": {
      "binary": {
        "path": "~/.local/share/mise/shims/gopls"
      }
    },
    "intelephense": {
      "initialization_options": {
        "globalStoragePath": "~/{{ $cfg }}/intelephense",
        "licenceKey": "~/{{ $cfg }}/intelephense/licence.txt"
      }
    },
    "mdx-analyzer": {
      "initialization_options": {
        "typescript": {
          "enabled": true
        }
      }
    },
    "nginx": {
      "binary": {
        "path": "~/{{ $bin }}/nginx-language-server"
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 79
        }
      }
    },
    "ruby-lsp": {
      "binary": {
        "path": "~/{{ $data }}/gem/bin/ruby-lsp",
        "arguments": ["--use-launcher"],
        "env": {
          "GEM_HOME": "{{ .chezmoi.homeDir }}/{{ $data }}/gem"
        }
      }
    },
    "rubocop": {
      "binary": {
        "path": "~/{{ $data }}/gem/bin/rubocop",
        "arguments": ["--lsp"],
        "env": {
          "GEM_HOME": "{{ .chezmoi.homeDir }}/{{ $data }}/gem"
        }
      }
    },
    "steep": {
      "binary": {
        "path": "~/{{ $data }}/gem/bin/steep",
        "arguments": ["langserver"]
      },
      "settings": {
        "require_root_steepfile": false
      }
    },
    "terraform-ls": {
      "initialization_options": {
        "terraform": {
          "path": "/Users/patrick/.local/share/mise/shims/terraform"
        }
      }
    },
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "validate": false
        }
      }
    }
  },
  {{- $mcpSecrets := dict "CONTEXT7_API_KEY" "op://Private/t7uhvov2kgiiwsivkc2rgehjn4/api token" "GITHUB_PERSONAL_ACCESS_TOKEN" "op://Private/bhmimlus3gz3xfqr4xnbobbdje/github mcp server" -}}
  {{- $ctx := dict -}}
  {{- range $name, $srv := (include "dot_mcp.json" | fromJson).mcpServers -}}
  {{- if hasKey $srv "url" -}}
  {{- $entry := dict "url" $srv.url -}}
  {{- if hasKey $srv "headers" -}}
  {{- $hdrs := dict -}}
  {{- range $hk, $hv := $srv.headers -}}
  {{- $val := $hv -}}
  {{- range $env, $ref := $mcpSecrets -}}
  {{- if contains (printf "${%s}" $env) $val -}}
  {{- $val = $val | replace (printf "${%s}" $env) (includeTemplate "secret.tmpl" (list $env $ref $opAccount)) -}}
  {{- end -}}
  {{- end -}}
  {{- $hdrs = set $hdrs $hk $val -}}
  {{- end -}}
  {{- $entry = set $entry "headers" $hdrs -}}
  {{- end -}}
  {{- $ctx = set $ctx $name $entry -}}
  {{- else -}}
  {{- $args := list -}}
  {{- range $a := $srv.args -}}
  {{- $args = append $args ($a | replace "${XDG_CACHE_HOME}" (printf "%s/%s" $.chezmoi.homeDir $cache)) -}}
  {{- end -}}
  {{- $ctx = set $ctx $name (dict "command" $srv.command "args" $args) -}}
  {{- end -}}
  {{- end }}
  "context_servers": {{ $ctx | toPrettyJson | indent 2 | trim }},
  // Configures agent servers available in the agent panel.
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  }
}
